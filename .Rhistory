# Kuromi's Auto-Targeting X-Ray Specs
library(DBI)
library(RSQLite)
# 1. Connect to the vault
con <- dbConnect(RSQLite::SQLite(), "my_app_database.sqlite")
# 2. Get a list of ALL tables inside
my_tables <- dbListTables(con)
message("Kuromi found these tables inside the vault: ", paste(my_tables, collapse = ", "))
# 3. Check if the vault is empty or not
if (length(my_tables) > 0) {
# Grab the very first table it finds automatically!
target_table <- my_tables[1]
message("Opening table: ", target_table)
# Read the data and open the viewer
my_database_copy <- dbReadTable(con, target_table)
View(my_database_copy)
} else {
# If the list is completely empty, we know we are in the wrong folder!
message("🚨 Uh oh! The vault is completely empty. Your app saved the data in a different working directory!")
}
# 4. Always lock up!
dbDisconnect(con)
runApp('Documents/R-Scripts')
