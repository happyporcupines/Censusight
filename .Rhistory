"sleep_ageadjprev", "binge_ageadjprev", "depression_ageadjprev")) {
# conversion of variables to formula objects
formula <- as.formula(paste("socialisolation_ageadjprev ~", var))
model <- lm(formula, data = places_summary) # Run the simple linear regression
print(paste("\n", var, ":")) # Print the variable name for readability
print(summary(model))}
# OLS baseline
# predicting social isolation via other health metrics
vif_model <- lm(socialisolation_ageadjprev ~ emotionalsupport_ageadjprev + mhlth_ageadjprev + sleep_ageadjprev + depression_ageadjprev, data = places_data)
# VIF
# If values are > 5 or 10, variables are too similar (multicollinearity)
vif_values <- vif(vif_model)
print(vif_values)
# Since "depression" and "mental health" were too correlated (high VIF), this testing is to see which performs better in-model
# Model A: Keep depression and drop the general mental health variable
model_A <- lm(socialisolation_ageadjprev ~ emotionalsupport_ageadjprev + sleep_ageadjprev + depression_ageadjprev, data = places_summary)
# Model B: Keeping mental health and dropping depression
model_B <- lm(socialisolation_ageadjprev ~ emotionalsupport_ageadjprev + sleep_ageadjprev + mhlth_ageadjprev, data = places_summary)
# Higher R-squared is better (explains more variance).
# Lower AIC is better (better fit with less complexity).
print(paste("Model A (Depression) Adj. R-squared:", round(summary(model_A)$adj.r.squared, 4)))
print(paste("Model B (Mental Health) Adj. R-squared:", round(summary(model_B)$adj.r.squared, 4)))
print(paste("Model A AIC:", round(AIC(model_A), 2)))
print(paste("Model B AIC:", round(AIC(model_B), 2)))
#setup layout
par(mfrow=c(2,2))
par(mar = c(4, 4, 2, 1))
# plot depression model
plot(model_A, main="Model A (Depression)")
#plot mental health model
plot(model_B, main="Model B (Mental Health)")
# Reset layout
par(mfrow=c(1,1))
#capture the curve
model_a_poly <- lm(socialisolation_ageadjprev ~ depression_ageadjprev + I(depression_ageadjprev^2), data = places_summary)
#stats check
summary(model_a_poly)
#flattening check
par(mfrow = c(2, 2), mar = c(4, 4, 2, 1))
plot(model_a_poly)
#using Cook's distance to extract outliers
cooks_d <- cooks.distance(model_a_poly)
sample_size <- nrow(places_summary)
threshold <- 4 / sample_size
# show residuals and use outlier filter
outliers <- places_summary[cooks_d > threshold, ]
outliers$residual_error <- residuals(model_a_poly)[cooks_d > threshold]
#show biggest outliers
outliers <- outliers[order(-outliers$residual_error), ]
#summary
print(paste("Number of outliers detected:", nrow(outliers)))
head(outliers) # shows the top 6 most extreme outliers
wi_places <- places(state = "WI", cb = TRUE, year = 2022)
# We use inner_join to keep ONLY the cities that exist in both datasets
places_mapped <- wi_places %>%
inner_join(places_summary, by = c("NAME" = "placename"))
#prepping coordinates
# of_largest_polygon = TRUE ensures the center is in the main city body, not skewed by tiny islands.
if(all(c("INTPTLON", "INTPTLAT") %in% colnames(places_mapped))) {
#Use existing columns if they survived the join for speed while ensuring numeric data
coords <- as.matrix(data.frame(x = as.numeric(places_mapped$INTPTLON), y = as.numeric(places_mapped$INTPTLAT)))
} else {
# calculate centroids if necessary
coords <- st_centroid(places_mapped, of_largest_polygon = TRUE) %>% st_coordinates()
}
#nearest neighbor search
# k=5 connects every city to its 5 closest peers
k_val <- 5
fnn_results <- get.knn(coords, k = k_val)
# Convert raw matrix output into an nb object for spdep
knn_bridge <- list(
nn = fnn_results$nn.index, # Matrix of neighbor indices
np = nrow(coords), # Total number of points
k = k_val, # Number of neighbors
dimension = 2, # 2D coordinates
x = coords # Coordinates
)
class(knn_bridge) <- "knn"
# Convert to standard neighbor list
nb <- knn2nb(knn_bridge)
#calculate inverse-distance gradient weights
#calculate physical distance between each city and its 5 neighbors
dists <- nbdists(nb, coords)
#convert distances to weights
idw <- lapply(dists, function(x) 1 / (x + 1e-5)) #adding 1e-5 prevents division by zero
#creating spatial weights using custom weights and weight standardization to sum to 1
lw_gradient <- nb2listw(nb, glist = idw, style = "W")
#show
print(lw_gradient)
#moran's I test
moran_results <- list()
#adding variables
vars_to_test <- c("socialisolation_ageadjprev", "emotionalsupport_ageadjprev", "mhlth_ageadjprev", "sleep_ageadjprev", "binge_ageadjprev", "depression_ageadjprev")
for (var in vars_to_test) {
if(var %in% names(places_mapped)) {
# Run Moran's
# use lw_gradient as the spatial weights
moran_results[[var]] <- moran.test(places_mapped[[var]], lw_gradient, na.action = na.omit)
# Print clean results
print(paste(var, "Moran's I:", round(moran_results[[var]]$estimate[1], 3), "p-value:", format.pval(moran_results[[var]]$p.value, digits=4)))
} else {
print(paste("Error"))
}
}
# localG returns a Z-score
# > 1.96 = Significant Hotspot (Red)
# < -1.96 = Significant Coldspot (Blue)
#using lw_gradient
gi_star <- localG(places_mapped$socialisolation_ageadjprev, lw_gradient)
# Add the result back to map for plotting
places_mapped$isolation_z_score <- as.numeric(gi_star)
tmap_mode("plot")
tm_shape(places_mapped) +
tm_polygons(col = "isolation_z_score",
style = "fixed",
breaks = c(-Inf, -1.96, 1.96, Inf),
palette = c("blue", "white", "red"),
labels = c("Coldspot (Low Isolation)", "Not Significant", "Hotspot (High Isolation)"),
title = "Isolation Hotspots (Gi*)") +
tm_layout(main.title = "Social Isolation Hotspots in Wisconsin",
legend.outside = TRUE)
census_api_key("c15b342da84bf3a9879f90762b6239a8bca4085c", overwrite = TRUE)
#adding population data
# Using the American Community Survey (ACS) 5-year estimates (most reliable current data)
# Variable "B01003_001" is total population
wi_pop <- get_acs(geography = "place", variables = "B01003_001", state = "WI", year = 2022,geometry = FALSE # no shapes just data
) %>%
select(GEOID, TotalPopulation = estimate)
#join by GEOID to places_mapped
places_with_pop <- places_mapped %>%
left_join(wi_pop, by = "GEOID")
#geting boundaries
wi_cbsa <- core_based_statistical_areas(cb = TRUE, year = 2022) %>%
filter(grepl("WI", NAME)) %>%
select(CBSA_Name = NAME, CBSA_Type = LSAD) %>%
st_transform(st_crs(places_with_pop)) # Ensure CRS matches
census_api_key("c15b342da84bf3a9879f90762b6239a8bca4085c", overwrite = TRUE)
#adding population data
# Using the American Community Survey (ACS) 5-year estimates (most reliable current data)
# Variable "B01003_001" is total population
wi_pop <- get_acs(geography = "place", variables = "B01003_001", state = "WI", year = 2022,geometry = FALSE # no shapes just data
) %>%
select(GEOID, TotalPopulation = estimate)
#join by GEOID to places_mapped
places_with_pop <- places_mapped %>%
left_join(wi_pop, by = "GEOID")
#geting boundaries
wi_cbsa <- core_based_statistical_areas(cb = TRUE, year = 2023) %>%
filter(grepl("WI", NAME)) %>%
select(CBSA_Name = NAME, CBSA_Type = LSAD) %>%
st_transform(st_crs(places_with_pop)) # Ensure CRS matches
#spatial join with classification
places_classified <- st_join(places_with_pop, wi_cbsa, join = st_intersects) %>%
mutate(
urban_category = case_when(
#RURAL (Not inside any Metro/Micro area)
is.na(CBSA_Type) ~ "Rural",
#TOWN (Inside a Micropolitan "M2" area)
CBSA_Type == "M2" ~ "Town",
#URBAN (Metro area + Pop >= 50k)
CBSA_Type == "M1" & TotalPopulation >= 50000 ~ "Urban",
#SUBURB (Metro area + Pop < 50k)
CBSA_Type == "M1" & TotalPopulation < 50000  ~ "Suburb",
# fallback for weird cases
TRUE ~ "Rural"
)
)
# Map it
tmap_mode("plot")
tm_shape(places_classified) +
tm_dots(col = "urban_category",
palette = c("Urban" = "red", "Suburb" = "orange", "Town" = "blue", "Rural" = "cyan"),
size = 0.1,
title = "City Classification")
#group by category and calculate averages
profile_summary <- places_classified %>%
st_drop_geometry() %>% # Dropping the map shapes for faster math
group_by(urban_category) %>%
summarise(
n_cities = n(),
Isolation = mean(socialisolation_ageadjprev, na.rm = TRUE),
EmotionalSupport_Lack = mean(emotionalsupport_ageadjprev, na.rm = TRUE),
MentalHealth_Poor = mean(mhlth_ageadjprev, na.rm = TRUE),
Sleep_Poor = mean(sleep_ageadjprev, na.rm = TRUE),
BingeDrinking = mean(binge_ageadjprev, na.rm = TRUE),
Depression = mean(depression_ageadjprev, na.rm = TRUE)
)
print("Average Health Profiles by Community Type")
print(profile_summary)
#boxplot setup
long_data <- places_classified %>%
st_drop_geometry() %>%
select(urban_category,
socialisolation_ageadjprev, emotionalsupport_ageadjprev,
mhlth_ageadjprev, sleep_ageadjprev,
binge_ageadjprev, depression_ageadjprev) %>%
pivot_longer(cols = -urban_category, names_to = "Variable", values_to = "Value")
#boxplotting
ggplot(long_data, aes(x = urban_category, y = Value, fill = urban_category)) +
geom_boxplot(alpha = 0.7) +
facet_wrap(~ Variable, scales = "free_y") + # 'free_y' lets each chart have its own range
theme_minimal() +
labs(title = "Health Profiles: Urban vs. Rural",
y = "Prevalence (%)",
x = "Community Type") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
#ANOVA loop test for statistical significance
vars_to_test <- c("socialisolation_ageadjprev", "emotionalsupport_ageadjprev", "mhlth_ageadjprev", "sleep_ageadjprev", "binge_ageadjprev", "depression_ageadjprev")
print("ANOVA Results")
for(var in vars_to_test) {
# Run ANOVA
# reformulate() creates the formula: variable ~ urban_category
aov_result <- aov(reformulate("urban_category", response = var), data = places_classified)
# Print P-value
p_val <- summary(aov_result)[[1]][["Pr(>F)"]][1]
sig_star <- ifelse(p_val < 0.05, "***", " ")
print(paste(var, "| P-value:", format.pval(p_val, digits=3), sig_star))
}
#calculate turkey letters for all variables
get_tukey_letters <- function(var_name, data) {
#ANOVA
f <- as.formula(paste(var_name, "~ urban_category"))
aov_model <- aov(f, data = data)
#Run Tukey HSD
tukey <- TukeyHSD(aov_model)
#Generate Letters
#multcompLetters4 extracts the "a, b, c" groups directly from the AOV object
letters_list <- multcompLetters4(aov_model, tukey)
# Extract the letters for 'urban_category'
letters_df <- as.data.frame(letters_list$urban_category$Letters)
colnames(letters_df) <- "Letter"
letters_df$urban_category <- rownames(letters_df)
return(letters_df)
}
# Loop through your variables and combine results
vars_to_test <- c("socialisolation_ageadjprev", "emotionalsupport_ageadjprev", "mhlth_ageadjprev", "sleep_ageadjprev", "binge_ageadjprev", "depression_ageadjprev")
plot_labels <- list()
for(var in vars_to_test) {
#Get letters
letters <- get_tukey_letters(var, places_classified)
letters$Variable <- var
#Get the MAX value for each group (so we can put the letter on top of the boxplot)
max_vals <- places_classified %>%
st_drop_geometry() %>%
group_by(urban_category) %>%
summarise(Max_Value = max(.data[[var]], na.rm = TRUE))
# Join them
combined <- left_join(letters, max_vals, by = "urban_category")
plot_labels[[var]] <- combined
}
# Bind into one big dataframe for plotting
final_labels <- do.call(rbind, plot_labels)
# Prepare main data for visualization
long_data <- places_classified %>%
st_drop_geometry() %>%
select(urban_category, all_of(vars_to_test)) %>%
pivot_longer(cols = -urban_category, names_to = "Variable", values_to = "Value")
# Plot
ggplot(long_data, aes(x = urban_category, y = Value, fill = urban_category)) +
geom_boxplot(alpha = 0.6, outlier.shape = 1) + # Light boxplots
# Add the Letters on top
geom_text(data = final_labels,
aes(x = urban_category, y = Max_Value, label = Letter),
vjust = -0.5, # Move text slightly up
size = 4,
fontface = "bold") +
facet_wrap(~ Variable, scales = "free_y") +
theme_minimal() +
labs(title = "Health Differences with Significance Groupings", subtitle = "Groups with different letters are significantly different (p < 0.05)", y = "Prevalence (%)", x = "") +
theme(legend.position = "none", axis.text.x = element_text(size = 10, face = "bold"))
#Convert SF map to spatial
places_sp <- as(places_mapped, "Spatial")
# Define the Formula
f <- socialisolation_ageadjprev ~ emotionalsupport_ageadjprev + sleep_ageadjprev + binge_ageadjprev + depression_ageadjprev
#OLS (Ordinary Least Squares)
ols <- lm(f, data = places_mapped)
#SLM (Spatial Lag Model)
slm <- lagsarlm(f, data = places_mapped, listw = lw_gradient)
# SEM (Spatial Error Model)
sem <- errorsarlm(f, data = places_mapped, listw = lw_gradient)
#GWR
#calculating optimal bandwidth
# adaptive = TRUE tells the model to look at the "N closest cities" rather than a fixed "10 miles".
# This prevents the model from breaking in rural areas where cities are far apart.
bw <- bw.gwr(f, data = places_sp, approach = "AICc", kernel = "bisquare", adaptive = TRUE)
#fitting the model
gwr_res <- gwr.basic(f, data = places_sp, bw = bw, kernel = "bisquare", adaptive = TRUE)
#results comparison
# Helper for pseudo_r2
get_pseudo_r2 <- function(model) {
1 - (model$SSE / sum((model$y - mean(model$y))^2))
}
comparison <- data.frame(Model = c("OLS", "SLM", "SEM", "GWR"),
# lower AIC is better
AIC = c(AIC(ols), AIC(slm), AIC(sem), gwr_res$GW.diagnostic$AICc),
# higher R-squared is better
R2 = c(summary(ols)$r.squared, get_pseudo_r2(slm), get_pseudo_r2(sem), gwr_res$GW.diagnostic$gw.R2))
print(comparison)
#usinng png export
tmap_mode("plot")
#folder creation
dir.create("GWR_Maps", showWarnings = FALSE)
#data prep
gwr_results_map <- st_as_sf(gwr_res$SDF)
gwr_results_map$NAME <- places_mapped$NAME # Fix missing names
vars_to_map <- c("Local_R2", "emotionalsupport_ageadjprev", "sleep_ageadjprev", "binge_ageadjprev", "depression_ageadjprev")
titles <- c("Model Accuracy (R2)","Emotional Support", "Sleep Quality","Binge Drinking","Depression")
#png map loop
for (i in 1:length(vars_to_map)) {
var_name <- vars_to_map[i]
tab_title <- titles[i]
# pallete
if (var_name == "Local_R2") {
pal <- "magma"
mid <- NA
legend_title <- "Local R-Squared"
} else {
pal <- "RdBu"
mid <- 0
legend_title <- "Coefficient Impact"
}
#map generation
m <- tm_shape(gwr_results_map) +
tm_polygons(col = var_name,
palette = pal,
midpoint = mid,
style = "quantile",
n = 7,
title = legend_title,
lwd = 0.1, # Thinner borders look better in static images
legend.show = TRUE) +
tm_layout(main.title = tab_title,
main.title.size = 1.2,
legend.position = c("left", "bottom"),
frame = FALSE)
#adding filenames
clean_name <- gsub(" ", "_", tab_title)
file_path <- paste0("GWR_Maps/", clean_name, ".png")
#saving
tmap_save(m, filename = file_path, width = 10, height = 8, dpi = 300)
print(paste("Saved:", file_path))
}
print("Maps made.")
