library(DBI)
library(RSQLite)
# 1. Connect straight to the Documents/R-Scripts vault!
db_path <- file.path(path.expand("~"), "Documents", "R-Scripts", "my_app_database.sqlite")
con <- dbConnect(RSQLite::SQLite(), db_path)
# 2. Get the tables
my_tables <- dbListTables(con)
if (length(my_tables) > 0) {
target_table <- my_tables[1]
message("Wicked! Opening table: ", target_table)
# Read and view!
my_database_copy <- dbReadTable(con, target_table)
View(my_database_copy)
} else {
message("🚨 Vault is still empty! Did you hit 'Process' in the app before stopping it?")
}
dbDisconnect(con)
